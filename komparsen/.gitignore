# .gitignore — Kast Komparsen-Agentur
# Laufzeitdaten nicht committen (enthalten Test-User + gemockte Mails)
data/db.json
data/mailbox/
node_modules/
*.log
.DS_Store
# Secrets niemals committen (DSGVO + Sicherheit)
.env
# Backups sind Artefakte, kein Quellcode
backups/

# DKIM privater Schlüssel (nie committen!)
data/dkim-private.pem
