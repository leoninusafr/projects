# KAST — .env Beispiel (kopieren nach .env, nie in Git!)
# Alle Werte optional. Fehlt einer, greift der sichere Mock/Log-Fallback.

# --- E-MAIL-VERSAND (Brevo Free = 300/Tag, 0€) ---
# Hol dir den API-Key auf brevo.com (Transaktional).
BREVO_API_KEY=
# Absender (muss bei Brevo verifiziert sein)
MAIL_FROM=KAST <noreply@kast.example>
# Öffentliche URL für Opt-In-Links (bei eigener Domain ändern)
APP_PUBLIC_URL=https://kast.example

# --- WHATSAPP (Meta Business Cloud API, kostenlos im Dev-Modus) ---
# 1) Meta-App erstellen (developers.facebook.com) + WhatsApp-Produkt
# 2) Phone-Number-ID + Temporary/Perm. Access-Token kopieren
# 3) hier eintragen -> WhatsApp ist live (kein Code-Wechsel nötig)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# --- EIGENES RELAY (optional, für Skalierung statt Brevo) ---
# SMTP oder eigenes Postfix — dann MAIL_MODE=own/SMTP setzen
MAIL_MODE=mock

# --- SUNSTIG ---
PORT=4173
HOST=0.0.0.0
# NETLIFY=1 nur in Netlify-Function (nicht lokal nötig)
