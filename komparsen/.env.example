# KAST — Umgebungsvariablen (Server-Config)
# Kopiere diese Datei zu .env und trage deine Werte ein.
# NIEMALS Secrets in db.json / Code / Git committen (DSGVO + Sicherheit).
#
# Start:  MAIL_PROVIDER=brevo MAIL_API_KEY=dein-key PORT=4173 node server.js
# ODER:   source .env && node server.js

# ───── E-MAIL-VERSAND (DSGVO: EU-Anbieter empfohlen) ─────
# Option A — BREVO (empfohlen, kostenlos 300/Tag, EU/Schrems-II)
#   1) Konto auf brevo.com anlegen (keine Kreditkarte)
#   2) https://app.brevo.com/ -> SMTP & API -> API-Keys -> Key erzeugen
#   3) Absender-Identität bestätigen (z.B. noreply@deinedomain.de)
MAIL_PROVIDER=brevo
MAIL_API_KEY=

# Option B — EIGENER SMTP (falls du später deine Domain nutzt)
# MAIL_PROVIDER=smtp
# MAIL_SMTP_HOST=smtp.deinedomain.de
# MAIL_SMTP_PORT=587
# MAIL_SMTP_TLS=0
# MAIL_SMTP_USER=api@deinedomain.de
# MAIL_SMTP_PASS=

# Absender (Name <email>) — MUSS beim Anbieter bestätigt sein
MAIL_FROM=KAST <noreply@kast.example>

# Öffentliche URL (für absolute Opt-In-Links in Mails — Pflicht für Produktion)
APP_PUBLIC_URL=https://kast.example

# ───── SERVER ─────
PORT=4173
HOST=0.0.0.0

# ───── WHATSAPP (optional, später) ─────
# WHATSAPP_TOKEN=
# WHATSAPP_FROM=
