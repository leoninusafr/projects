# KAST — Umgebungsvariablen (Server-Config)
# Kopiere diese Datei zu .env und trage deine Werte ein.
# NIEMALS Secrets in db.json / Code / Git committen (DSGVO + Sicherheit).
#
# Start:  MAIL_MODE=brevo MAIL_API_KEY=dein-key PORT=4173 node server.js
# ODER:   source .env && node server.js

# ───── E-MAIL-VERSAND ─────
# MAIL_MODE: welcher Anbieter AKTIV ist (brevo | smtp | own | mock)
#   brevo -> Brevo REST-API (EU/Schrems-II, Free 300/Tag, 0€)
#   smtp  -> eigenes SMTP (Open-Source Postfix/OpenDKIM auf eigenem Server)
#   own   -> eigenes Relay (vorbereitet, setze OWN_SMTP_* dazu)
#   mock  -> nur lokale Datei (Entwicklung)
MAIL_MODE=brevo
MAIL_API_KEY=

# SKALIERUNG: was nach Brevo-Tageslimit (300/Tag Free) passiert?
#   queue_next_day -> Mail in Pending-Queue, nächster Tag nachgeholt (kein Verlust)
#   failover_own   -> eigenes Relay (OWN_SMTP_*) übernimmt, falls konfiguriert
MAIL_QUOTA_POLICY=queue_next_day

# Optionale Typ-Routen (leer = MAIL_MODE). Admin kann im Panel überschreiben.
# MAIL_ROUTE_OPTIN=brevo
# MAIL_ROUTE_BOOKING=brevo
# MAIL_ROUTE_ADMIN=brevo

# EIGENES SMTP / RELAY (optional, für Skalierung)
# MAIL_SMTP_HOST=smtp.deinedomain.de
# MAIL_SMTP_PORT=587
# MAIL_SMTP_TLS=0
# MAIL_SMTP_USER=api@deinedomain.de
# MAIL_SMTP_PASS=
# OWN_SMTP_HOST=relay.deinedomain.de   # eigenes Relay (Postfix/OpenDKIM)
# OWN_SMTP_PORT=587
# OWN_SMTP_USER=
# OWN_SMTP_PASS=

# Absender (Name <email>) — MUSS beim Anbieter bestätigt sein
MAIL_FROM=KAST <noreply@kast.example>

# Öffentliche URL (für absolute Opt-In-Links in Mails — Pflicht für Produktion)
APP_PUBLIC_URL=https://kast.example

# ───── SERVER ─────
PORT=4173
HOST=0.0.0.0

# ───── WHATSAPP (optional, später) ─────
# WHATSAPP_TOKEN=
# WHATSAPP_FROM=
